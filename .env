# ============================================================
# 通用环境变量配置
# ============================================================
# 说明：此文件中的变量在所有环境下都会加载
# 注意：VITE_ 前缀的变量才会暴露给客户端代码
# ============================================================

# API 请求基础路径（用于 axios 等请求库的 baseURL）
VITE_APP_API_BASEURL = /api

# Mock API 请求基础路径（用于开发环境 Mock 数据）
VITE_APP_MOCK_BASEURL = /mock/api
